datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Ini pola tabel untuk database Neon Anda
model Transaction {
  id Int @id @default(autoincrement())
  title String
  amount Float
  type String
  createAt DateTime @default(now())
  userId Int
  user User @relation(fields: [userId], references: [id])
}

model User {
  id Int @id @default(autoincrement())
  name String?
  email String @unique
  password String
  image String?
  resetToken String?
  resetTokenExpires DateTime?
  createdAt DateTime @default(now())
  transactions Transaction[]
}