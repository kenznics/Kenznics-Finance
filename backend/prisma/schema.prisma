datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Ini pola tabel untuk database Neon Anda
model Transaction {
  id Int @id @default(autoincrement())
  title String
  amount Float
  type String
  createAt DateTime @default(now())
  userId Int
  user User @relation(fields: [userId], references: [id])
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  password String
  createdAt DateTime @default(now())
  trasactions Transaction[]
}